{
  // Cline がルールファイルを読み込む設定
  "cline.customInstructions": ".clinerules",
  "cline.rules": ".clinerules",

  // Memory Bank: セッション開始時に参照するコンテキストファイル
  // Cline に「cline_docs/ を読む」と 40-memory-bank.md で指示しているため
  // ここでは追加パスをコメントとして明示しておく
  // 対象: cline_docs/projectbrief.md / techContext.md / activeContext.md / progress.md

  // C# / Unity 向けエディタ設定
  "editor.formatOnSave": true,
  "editor.insertSpaces": true,
  "editor.tabSize": 4,
  "files.encoding": "utf8",
  "files.eol": "\n",

  // Unity 自動生成ファイルをエクスプローラーで非表示
  "files.exclude": {
    "**/Library": true,
    "**/Temp": true,
    "**/Obj": true,
    "**/Logs": true,
    "**/UserSettings": true,
    "**/*.pidb": true,
    "**/*.booproj": true,
    "**/*.svd": true,
    "**/*.userprefs": true
  },

  // Cline に渡すファイルの検索対象から除外（LFSバイナリ・自動生成）
  "search.exclude": {
    "**/Library": true,
    "**/Temp": true,
    "**/Logs": true,
    "**/node_modules": true
  }
}
